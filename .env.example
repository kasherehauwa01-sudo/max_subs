# Базовый URL API MAX (обычно менять не нужно)
MAX_API_BASE_URL=https://platform-api.max.ru

# Токен вашего бота MAX
MAX_BOT_TOKEN=your_max_bot_token

# Таймаут HTTP-запросов к MAX API в секундах
MAX_TIMEOUT_SECONDS=10

# Количество ретраев на 429/503 и сетевые ошибки
MAX_API_MAX_RETRIES=5

# Секрет webhook (должен совпадать с secret при POST /subscriptions)
MAX_WEBHOOK_SECRET=your_webhook_secret

# TTL (сек) для in-memory dedup повторно доставленных webhook-событий
MAX_DEDUP_TTL_SECONDS=3600

# Уровень логирования
LOG_LEVEL=INFO

# Публичный URL webhook вашего бота (для регистрации через /setup/subscription)
MAX_WEBHOOK_URL=https://maxsubs-production.up.railway.app/webhook

# Если MAX_WEBHOOK_URL не задан, URL будет собран автоматически:
# https://$RAILWAY_PUBLIC_DOMAIN/webhook
# RAILWAY_PUBLIC_DOMAIN выставляется Railway при включённом Public Domain

# Какие типы событий подписывать при регистрации webhook
MAX_WEBHOOK_UPDATE_TYPES=message_created,bot_started,message_callback

# chat_id канала для проверки подписки в миниприложении
MAX_CHANNEL_CHAT_ID=-72559954357735

# Ссылка на канал для кнопки "Подписаться на канал" в миниприложении
MAX_CHANNEL_URL=https://web.max.ru/-72559954357735

# Deep-link канала для открытия внутри приложения MAX (используется в кнопке miniapp в приоритете)
MAX_CHANNEL_DEEPLINK=max://chat/-72559954357735

# Username бота/miniapp для поля web_app в кнопке open_app (опционально).
# Пример: my_coupon_bot (без @). Если пусто, бот отправит fallback-кнопку link на /miniapp.
MAX_WEB_APP=

# Публичный базовый URL приложения (если нужно явно задать URL миниприложения)
# Например: https://maxsubs-production.up.railway.app
PUBLIC_BASE_URL=

# Автоматически регистрировать webhook в MAX при старте приложения
MAX_WEBHOOK_AUTO_REGISTER=true

# Выполнять проверку MAX API (/me) при старте и писать результат в логи
MAX_STARTUP_SELF_CHECK=false
