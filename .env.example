# Базовый URL API MAX (обычно менять не нужно)
MAX_API_BASE_URL=https://platform-api.max.ru

# Токен вашего бота MAX
MAX_BOT_TOKEN=your_max_bot_token

# Таймаут HTTP-запросов к MAX API в секундах
MAX_TIMEOUT_SECONDS=10

# Количество ретраев на 429/503 и сетевые ошибки
MAX_API_MAX_RETRIES=5

# Секрет webhook (должен совпадать с secret при POST /subscriptions)
MAX_WEBHOOK_SECRET=your_webhook_secret

# TTL (сек) для in-memory dedup повторно доставленных webhook-событий
MAX_DEDUP_TTL_SECONDS=3600

# Уровень логирования
LOG_LEVEL=INFO
